# Environment Configuration (all optional — sensible defaults exist)

# App Settings
DEBUG=False

# Server Settings
HOST=0.0.0.0
PORT=8000

# File Upload Settings (in bytes)
MAX_UPLOAD_SIZE=536870912  # 500 MB

# CORS: the deployed frontend origin (localhost origins are always allowed).
# Set this on the production backend host (e.g. Render) to your Vercel URL.
FRONTEND_URL=https://your-app.vercel.app
